# Python build artefacts
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
.mypy_cache/
build/
dist/

# Virtual envs
.venv/
.env
.env.local

# uv
uv-receipt.json

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Frontend build output (regenerated by `make frontend-build`).
# The wheel `force-include`s this directory; build_hooks/spa_check.py
# fails the build if it's empty when packaging a non-editable wheel.
src/pd_ocr_labeler_spa/static/*
!src/pd_ocr_labeler_spa/static/.gitkeep

# Frontend (lands in M0 part 2)
frontend/node_modules/
frontend/dist/
frontend/openapi.json
frontend/coverage/
# Incremental TypeScript build cache — regenerated on every `tsc -b`,
# never load-bearing for reproducibility (unlike package-lock.json,
# which IS committed).
frontend/*.tsbuildinfo

# Playwright
test-results/
playwright-report/

# Claude Code session state — agent memory canonical home is
# /workspaces/ocr-container/.claude/agent-memory/, not per-repo. If you
# see a .claude/ tree here, it is leakage; clean it up.
.claude/

# Hourly-regenerated spec-chain dashboard — workspace-only artifact, not source.
docs/spec-chain-report.md

# ship-issue bot temp cache (issue JSON written by ship-issue-pick.py)
.ship-issue-tmp/

# AI=1 make output capture log
.ci-ai.log

# Runtime port file written by the server on every start (issue #323).
# Consumed by vite.config.ts during `npm run dev` to proxy to the correct port.
.pdlabeler-port
